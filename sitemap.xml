---
---
<?xml version="1.0" encoding="UTF-8"?>

<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% assign build_date = site.time | date: "%Y-%m-%d" %}

  <url>
    <loc>{{ "/" | absolute_url }}</loc>
    <lastmod>{{ build_date }}</lastmod>
  </url>

  <url>
    <loc>{{ "/guides/" | absolute_url }}</loc>
    <lastmod>{{ build_date }}</lastmod>
  </url>

  {% assign sorted_guides = site.data.guides | sort: "order" %}
  {% for guide in sorted_guides %}
    {% if guide.url and guide.url contains "://" == false %}
      <url>
        <loc>{{ guide.url | absolute_url }}</loc>
        <lastmod>{{ build_date }}</lastmod>
      </url>
    {% endif %}
  {% endfor %}

  <url>
    <loc>{{ "/updates/" | absolute_url }}</loc>
    <lastmod>{{ build_date }}</lastmod>
  </url>

  {% assign sorted_updates = site.updates | sort: "date" | reverse %}
  {% for update in sorted_updates %}
    <url>
      <loc>{{ update.url | absolute_url }}</loc>
      <lastmod>{{ update.date | date: "%Y-%m-%d" }}</lastmod>
    </url>
  {% endfor %}
</urlset>
