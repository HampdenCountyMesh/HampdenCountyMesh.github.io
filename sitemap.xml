---
---
<?xml version="1.0" encoding="UTF-8"?>

<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% assign build_date = site.time | date: "%Y-%m-%d" %}

  <url>
    <loc>{{ "/" | absolute_url }}</loc>
    <lastmod>{{ build_date }}</lastmod>
  </url>

  <url>
    <loc>{{ "/guides/" | absolute_url }}</loc>
    <lastmod>{{ build_date }}</lastmod>
  </url>

  <url>
    <loc>{{ "/guides/getting-started.html" | absolute_url }}</loc>
    <lastmod>{{ build_date }}</lastmod>
  </url>

  <url>
    <loc>{{ "/guides/recommended-settings.html" | absolute_url }}</loc>
    <lastmod>{{ build_date }}</lastmod>
  </url>

  <url>
    <loc>{{ "/guides/meshcore-basics.html" | absolute_url }}</loc>
    <lastmod>{{ build_date }}</lastmod>
  </url>

  <url>
    <loc>{{ "/guides/meshtastic-basics.html" | absolute_url }}</loc>
    <lastmod>{{ build_date }}</lastmod>
  </url>

  <url>
    <loc>{{ "/guides/sharing-safely.html" | absolute_url }}</loc>
    <lastmod>{{ build_date }}</lastmod>
  </url>

  <url>
    <loc>{{ "/coverage.html" | absolute_url }}</loc>
    <lastmod>{{ build_date }}</lastmod>
  </url>

  <url>
    <loc>{{ "/updates/" | absolute_url }}</loc>
    <lastmod>{{ build_date }}</lastmod>
  </url>

  {% assign sorted_updates = site.updates | sort: "date" | reverse %}
  {% for update in sorted_updates %}
  <url>
    <loc>{{ update.url | absolute_url }}</loc>
    <lastmod>{{ update.date | date: "%Y-%m-%d" }}</lastmod>
  </url>
  {% endfor %}
</urlset>